    "# Add interaction terms to X_train and X_test\n",
    "X_train_interact = X_train.copy()\n",
    "X_test_interact = X_test.copy()\n",
    "\n",
    "X_train_interact[\"AGE_x_EMPLOYED\"] = X_train[\"AGE_YEARS\"] * X_train[\"YEARS_EMPLOYED\"]\n",
    "X_test_interact[\"AGE_x_EMPLOYED\"] = X_test[\"AGE_YEARS\"] * X_test[\"YEARS_EMPLOYED\"]\n",
    "\n",
    "X_train_interact[\"INCOME_x_CHILDREN\"] = X_train[\"AMT_INCOME_TOTAL\"] * X_train[\"CNT_CHILDREN\"]\n",
    "X_test_interact[\"INCOME_x_CHILDREN\"] = X_test[\"AMT_INCOME_TOTAL\"] * X_test[\"CNT_CHILDREN\"]\n",
    "\n",
    "lr_elastic_model_interaction = LogisticRegression(\n",
    "    penalty='elasticnet',\n",
    "    max_iter=5000,\n",
    "    solver=\"saga\",\n",
    "    random_state=42,\n",
    ")\n",
    "\n",
    "lr_elastic_param_grid_interaction = {\n",
    "    \"model__C\": [0.01, 0.1, 1, 10],\n",
    "    \"model__l1_ratio\": [0, 0.2, 0.5, 0.8, 1]  # mix of L1 and L2 (inclusive of L1 and L2)\n",
    "}\n",
    "\n",
    "# Build pipeline with new preprocessor\n",
    "lr_interact_grid = train_with_gridsearch(\n",
    "    model=lr_elastic_model_interaction,\n",
    "    param_grid=lr_elastic_param_grid_interaction,\n",
    "    X_train=X_train_interact,\n",
    "    y_train=y_train,\n",
    "    cv_folds=5,\n",
    "    scoring=\"roc_auc\",\n",
    "    use_smote=True,\n",
    "    n_jobs=1,\n",
    "    preprocessor=preprocessor_smote  # ← pass new preprocessor\n",
    ")\n",
    "\n",
    "print(\"\\n=== Elastic Net with Interaction Terms ===\")\n",
    "lr_interact_results = evaluate_model(lr_interact_grid, X_test_interact, y_test)"
   ]
  },
