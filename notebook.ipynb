    "from sklearn.model_selection import GridSearchCV, StratifiedKFold\n",
    "from sklearn.metrics import (\n",
    "    classification_report,\n",
    "    confusion_matrix,\n",
    "    ConfusionMatrixDisplay,\n",
    "    roc_auc_score,\n",
    "    roc_curve,\n",
    "    f1_score,\n",
    "    make_scorer,\n",
    ")\n",
    "\n",
    "\n",
    "def build_pipeline(model, preprocessor=preprocessor_smote, use_smote=True, smote_random_state=42, use_smotenc=False, categorical_indices=None):\n",
    "    \"\"\"Build an imbalanced-learn pipeline: preprocessor -> (optional) SMOTE -> model.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    model : sklearn estimator\n",
    "        Any classifier with a sklearn-compatible API.\n",
    "    preprocessor : ColumnTransformer\n",
    "        The preprocessing step (scaling + encoding).\n",
    "    use_smote : bool\n",
    "        Whether to include SMOTE oversampling in the pipeline.\n",
    "    smote_random_state : int\n",
    "        Random state for SMOTE reproducibility。\n",
    "    use_smotenc : bool\n",
    "        Whether to use SMOTENC instead of SMOTE (for datasets with categorical variables).\n",
    "    categorical_features : list\n",
    "        List of indices of categorical columns (required for SMOTENC).\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    ImbPipeline\n",
    "        A pipeline that can be passed directly to GridSearchCV.\n",
    "    \"\"\"\n",
    "    steps = []\n",
    "\n",
    "    if use_smotenc and categorical_indices is not None:\n",
    "        # SMOTENC BEFORE encoding\n",
    "        steps.append((\"preprocessor\", preprocessor_smotenc))\n",
    "        steps.append((\"smote\", SMOTENC(\n",
    "            categorical_features=categorical_indices,\n",
    "            random_state=smote_random_state\n",
    "        )))\n",
    "        # One hot encode only categorical columns AFTER SMOTENC\n",
    "        steps.append((\"encoder\", ColumnTransformer(\n",
    "        transformers=[\n",
    "            (\"cat\", OneHotEncoder(\n",
    "                drop=\"first\",\n",
    "                handle_unknown=\"infrequent_if_exist\",\n",
    "                sparse_output=False\n",
    "            ), categorical_indices)  # ← only categorical indices!\n",
    "        ],\n",
    "        remainder=\"passthrough\"  # ← keep numerical columns as is\n",
    "    )))\n",
    "    else:\n",
    "        # Regular SMOTE AFTER encoding\n",
    "        steps.append((\"preprocessor\", preprocessor_smote))\n",
    "        if use_smote:\n",
    "            steps.append((\"smote\", SMOTE(random_state=smote_random_state)))\n",
    "\n",
    "    steps.append((\"model\", model))\n",
    "    return ImbPipeline(steps)"
   ]
